{
  "compilerOptions": {
    "esModuleInterop": true,
    "types": ["node", "chai"],
    "forceConsistentCasingInFileNames": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "allowImportingTsExtensions": true
  }
}
